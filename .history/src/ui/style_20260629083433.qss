            background-color: #FFFFFF;
        }
        QCheckBox::indicator:hover {
            border-color: @C10@;
        }
        QCheckBox::indicator:checked {
            background-color: @C6@;
            border-color: @C6@;
            image: url(:/images/ui/check.svg);
        }
