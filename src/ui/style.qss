            background-color: @C25@;
            border: none;
            border-radius: @C9@px;
        }
        QLabel#aiInputBadge {
            background-color: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                stop:0 #2563EB, stop:1 #7C3AED);
            border: none;
            border-radius: 7px;
        }
        QLabel#aiInputHint {
            color: #9CA3AF;
            font-size: 14px;
        }
        QFrame#aiInputContent {
            background-color: @C22@;
            border: 1px solid @C4@;
            border-radius: @C9@px;
        }
        QPlainTextEdit#aiChatInput {
            background-color: transparent;
            border: none;
            color: @C26@;
            font-size: 14px;
            padding: 0;
        }
        QScrollArea#aiChipScroll {
            background-color: transparent;
            border: none;
        }
        QWidget#aiChipHost {
            background-color: transparent;
        }
        QPushButton#aiActionChip {
            background-color: #F3F4F6;
            color: #6B7280;
            border: 1px solid #E5E9F0;
            border-radius: 8px;
            padding: 0 10px;
            min-height: 32px;
            max-height: 32px;
            font-size: 12px;
        }
        QPushButton#aiActionChip:hover {
            color: @C6@;
            border-color: #BFDBFE;
            background-color: @C7@;
        }
        QPushButton#aiActionChip[selected="true"] {
            background-color: @C7@;
            color: @C6@;
            border-color: #BFDBFE;
            font-weight: 500;
        }
        QPushButton#aiSendButton {
            background-color: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                stop:0 #2563EB, stop:1 #1D4ED8);
            color: #FFFFFF;
            border: none;
            border-radius: 10px;
        }
        QPushButton#aiSendButton:hover {
            background-color: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                stop:0 #3B82F6, stop:1 #2563EB);
        }
        QPushButton#aiSendButton:disabled {
            background-color: @C10@;
        }
        QPushButton#aiStopButton {
            background-color: @C25@;
            color: @C14@;
            border: 1px solid #FFD4D0;
            border-radius: 10px;
        }
        QPushButton#aiStopButton:hover {
            background-color: #FFF1F0;
        }
        QPushButton#httpSendButton {
            background-color: @C6@;
            color: #FFFFFF;
            border: 1px solid @C6@;
            border-radius: @C5@px;
            padding: 5px 16px;
            min-height: 20px;
            font-weight: 500;
        }
        QPushButton#httpSendButton:hover {
            background-color: #4096FF;
            border-color: #4096FF;
        }
        QPushButton#httpSendButton:disabled {
            background-color: @C10@;
            border-color: @C10@;
            color: #FFFFFF;
        }
        QPushButton#moduleTabButton {
            background-color: transparent;
            color: @C3@;
            border: 1px solid transparent;
            border-radius: @C5@px;
            padding: 0 16px;
            min-height: 36px;
            font-size: 14px;
            font-weight: 500;
        }
        QPushButton#moduleTabButton:hover,
        QPushButton#moduleTabButton:checked,
        QPushButton#moduleTabButton:checked:hover {
            background-color: @C6@;
            color: #FFFFFF;
            border: 1px solid @C6@;
        }
        QPushButton#lineTabButton {
            background-color: transparent;
            color: @C3@;
            border: none;
            border-bottom: 2px solid transparent;
            border-radius: 0;
            padding: 8px 4px;
            min-height: 28px;
            margin-bottom: -1px;
            font-size: 13px;
            font-weight: 400;
        }
        QPushButton#lineTabButton:hover {
            color: @C6@;
        }
        QPushButton#lineTabButton:checked {
            color: @C6@;
            font-weight: 500;
            border-bottom: 2px solid @C6@;
        }
        QPushButton#lineTabButton:checked:hover {
            color: @C6@;
            background-color: transparent;
        }
        QPushButton#tabButton {
            background-color: transparent;
            color: @C3@;
            border: 1px solid transparent;
            border-radius: @C5@px;
            padding: 6px 12px;
            min-height: 16px;
            font-weight: 400;
        }
        QPushButton#tabButton:hover {
            color: @C6@;
            background-color: @C8@;
            border-color: transparent;
        }
        QPushButton#tabButton:checked {
            color: #FFFFFF;
            font-weight: 500;
            background-color: @C6@;
            border: 1px solid @C6@;
        }
        QPushButton#tabButton:checked:hover {
            background-color: #4096FF;
            border-color: #4096FF;
        }
        QPushButton#backNavButton {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C5@px;
            padding: 0;
            min-width: 28px;
            max-width: 28px;
            min-height: 28px;
            max-height: 28px;
        }
        QPushButton#backNavButton:hover {
            color: @C6@;
            border-color: @C10@;
            background-color: @C25@;
        }
        QPushButton#backNavButton:pressed {
            background-color: @C8@;
        }
        QPushButton#tableActionView {
            color: @C6@;
            background-color: transparent;
            border: none;
            padding: 0 4px;
            min-width: 0;
            min-height: 0;
            font-weight: 400;
        }
        QPushButton#tableActionView:hover {
            color: #4096FF;
            background-color: transparent;
        }
        QPushButton#tableActionWrite {
            color: #FF7D00;
            background-color: transparent;
            border: none;
            padding: 0 4px;
            min-width: 0;
            min-height: 0;
            font-weight: 400;
        }
        QPushButton#tableActionWrite:hover {
            color: #D35400;
            background-color: transparent;
        }
        QPushButton#tableActionDelete {
            color: @C14@;
            background-color: transparent;
            border: none;
            padding: 0 4px;
            min-width: 0;
            min-height: 0;
            font-weight: 400;
        }
        QPushButton#tableActionDelete:hover {
            color: #CB2634;
            background-color: transparent;
        }
        QLabel#healthTagGreen {
            color: #006435;
            background-color: #D4F1DC;
            border: 1px solid #A9E0B8;
            border-radius: @C11@px;
            padding: 2px 8px;
            font-weight: 500;
            font-size: 12px;
        }
        QLabel#healthTagYellow {
            color: #A35200;
            background-color: #FFF3E8;
            border: 1px solid #FFD4B8;
            border-radius: @C11@px;
            padding: 2px 8px;
            font-weight: 500;
            font-size: 12px;
        }
        QLabel#healthTagRed {
            color: #CB2634;
            background-color: #FFECE8;
            border: 1px solid #FFCCC7;
            border-radius: @C11@px;
            padding: 2px 8px;
            font-weight: 500;
            font-size: 12px;
        }
        QPushButton#dangerButton {
            background-color: #FFF1F0;
            color: @C14@;
            border: 1px solid #FFCCC7;
            border-radius: @C5@px;
            padding: 0 12px;
            min-height: 32px;
            max-height: 32px;
            font-size: 14px;
            font-weight: 400;
            transition: all 0.2s cubic-bezier(0.645, 0.045, 0.355, 1);
        }
        QPushButton#dangerButton:hover {
            background-color: #FFECE8;
            border-color: @C14@;
            color: #CB2634;
        }
        QPushButton#dangerButton:pressed {
            background-color: #FFC9C4;
            color: #CB2634;
        }
        QPushButton#dangerButton:disabled {
            background-color: #FFF1F0;
            color: #C8D0DA;
            border-color: #FFE8E5;
        }
        QPushButton[serviceToolbar="true"] {
            min-height: 32px;
            max-height: 32px;
            min-width: 96px;
            max-width: 96px;
        }
        QProgressBar {
            background-color: @C8@;
            border: 1px solid transparent;
            border-radius: @C11@px;
            text-align: center;
            color: @C3@;
            height: 18px;
            font-size: 11px;
        }
        QProgressBar::chunk {
            background-color: @C6@;
            border-radius: @C11@px;
        }
        QToolBar#pageToolbar {
            background: transparent;
            border: none;
            spacing: 8px;
            padding: 0;
            margin: 0;
        }
        QDialog {
            background-color: @C25@;
        }
        QDialog QFormLayout QLabel {
            color: @C2@;
            font-weight: 400;
            min-width: 68px;
            padding-right: 4px;
        }
        QInputDialog, QMessageBox {
            background-color: @C25@;
        }
        QInputDialog QLabel, QMessageBox QLabel {
            color: @C2@;
            background: transparent;
        }
        QInputDialog QLineEdit, QMessageBox QLineEdit {
            background-color: @C25@;
            color: @C2@;
            border: 1px solid @C4@;
            border-radius: @C5@px;
            padding: 6px 10px;
        }
        QMessageBox {
            color: @C2@;
        }
        QMenu {
            background-color: @C25@;
            color: @C2@;
            border: 1px solid @C4@;
            border-radius: @C5@px;
            padding: 4px;
        }
        QMenu::item {
            padding: 6px 20px 6px 12px;
            border-radius: @C11@px;
            color: @C2@;
            background-color: transparent;
        }
        QMenu::item:selected {
            background-color: @C7@;
            color: @C6@;
        }
        QMenu::item:disabled {
            color: @C13@;
        }
        QMenu::separator {
            height: 1px;
            background: @C8@;
            margin: 2px 6px;
        }
        QProgressBar#remoteUploadProgress {
            background-color: @C8@;
            border: 1px solid @C4@;
            border-radius: @C5@px;
            text-align: center;
            color: @C3@;
            font-size: 11px;
        }
        QProgressBar#remoteUploadProgress::chunk {
            background-color: @C6@;
            border-radius: @C5@px;
        }
        QDialogButtonBox {
            background: transparent;
        }
        QScrollBar:vertical {
            background: transparent;
            width: 8px;
            margin: 2px 0;
        }
        QScrollBar::handle:vertical {
            background: #C9CDD4;
            border-radius: 4px;
            min-height: 28px;
        }
        QScrollBar::handle:vertical:hover {
            background: #A8ABB2;
        }
        QScrollBar::add-line:vertical,
        QScrollBar::sub-line:vertical,
        QScrollBar::add-page:vertical,
        QScrollBar::sub-page:vertical {
            background: transparent;
            height: 0;
            width: 0;
        }
        QScrollBar:horizontal {
            background: transparent;
            height: 8px;
            margin: 0 2px;
        }
        QScrollBar::handle:horizontal {
            background: #C9CDD4;
            border-radius: 4px;
            min-width: 28px;
        }
        QScrollBar::handle:horizontal:hover {
            background: #A8ABB2;
        }
        QScrollBar::add-line:horizontal,
        QScrollBar::sub-line:horizontal,
        QScrollBar::add-page:horizontal,
        QScrollBar::sub-page:horizontal {
            background: transparent;
            height: 0;
            width: 0;
        }
        QCheckBox {
            color: @C2@;
            spacing: 6px;
        }
        QCheckBox::indicator {
            width: 16px;
            height: 16px;
            border: 1px solid @C4@;
            border-radius: 4px;
            background-color: @C25@;
        }
        QCheckBox::indicator:hover {
            border-color: @C10@;
        }
        QCheckBox::indicator:checked {
            background-color: @C6@;
            border-color: @C6@;
            image: url(:/images/ui/check.svg);
        }
        QLabel#projectDetailName {
            font-size: 18px;
            font-weight: 600;
            color: @C2@;
            padding: 0;
            margin: 0;
        }
        QLabel#projectDetailMetaLabel {
            color: @C3@;
            font-size: 13px;
            padding: 0;
            margin: 0;
            min-width: 60px;
        }
        QLabel#projectDetailMetaValue {
            color: @C2@;
            font-size: 13px;
            padding: 0;
            margin: 0;
        }
        QFrame#toolCard {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C9@px;
        }
        QPlainTextEdit#toolEditorText {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C5@px;
            padding: 8px;
            font-family: "JetBrains Mono", "Consolas", "Microsoft YaHei Mono", monospace;
            font-size: 13px;
            color: @C2@;
            selection-background-color: @C7@;
        }
        QPlainTextEdit#toolEditorText:focus {
            border-color: @C6@;
        }
        QPlainTextEdit#sqlCodeEditor {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C5@px;
            padding: 8px;
            font-family: "JetBrains Mono", "Consolas", "Microsoft YaHei Mono", monospace;
            font-size: 13px;
            color: @C2@;
            selection-background-color: @C6@;
            selection-color: @C25@;
        }
        QPlainTextEdit#sqlCodeEditor:focus {
            border-color: @C6@;
        }
        QPushButton#toolPrimaryButton {
            background-color: @C6@;
            color: #FFFFFF;
            border: none;
            border-radius: @C5@px;
            padding: 0 12px;
            min-height: 36px;
            font-size: 14px;
            font-weight: 500;
        }
        QPushButton#toolPrimaryButton:hover {
            background-color: @C10@;
            color: #FFFFFF;
        }
        QPushButton#toolPrimaryButton:pressed {
            background-color: #0958D9;
            color: #FFFFFF;
        }
        QPushButton#toolAiAssistButton {
            background-color: @C7@;
