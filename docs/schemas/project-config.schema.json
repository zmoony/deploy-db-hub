{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deploy-hub.local/schemas/project-config.schema.json",
  "title": "DeployHubProjectConfig",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "type",
    "source",
    "build",
    "deploy"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "group": {
      "type": "string",
      "description": "Optional project group label for filtering in the project list"
    },
    "type": {
      "type": "string",
      "enum": [
        "java-maven",
        "frontend-static",
        "python",
        "custom"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["local", "github"]
        },
        "localPath": {
          "type": ["string", "null"]
        },
        "repoUrl": {
          "type": "string",
          "format": "uri"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "local" } },
            "required": ["kind"]
          },
          "then": {
            "required": ["localPath"],
            "properties": {
              "localPath": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "github" } },
            "required": ["kind"]
          },
          "then": {
            "required": ["repoUrl", "ref"]
          }
        }
      ]
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "location",
        "workingDir",
        "artifactPath",
        "artifactMatchPolicy",
        "env",
        "timeoutSec"
      ],
      "properties": {
        "location": {
          "type": "string",
          "const": "local"
        },
        "mode": {
          "type": "string",
          "enum": ["build", "prebuilt-jar"],
          "default": "build",
          "description": "prebuilt-jar only available for java-maven projects"
        },
        "workingDir": {
          "type": "string",
          "default": "."
        },
        "command": {
          "type": "string",
          "description": "Required when mode=build. e.g. mvn clean package -DskipTests, npm run build"
        },
        "artifactPath": {
          "type": "string",
          "minLength": 1,
          "description": "For java-maven: glob pattern relative to project root (e.g. target/*.jar). For frontend-static: directory name relative to working dir (e.g. dist)"
        },
        "prebuiltJarPath": {
          "type": "string",
          "description": "Local absolute path to a prebuilt JAR (java-maven mode=prebuilt-jar only)"
        },
        "artifactRename": {
          "type": "string",
          "minLength": 1,
          "description": "For frontend-static: target directory name on remote server. If empty, files are uploaded directly to remoteBaseDir"
        },
        "artifactMatchPolicy": {
          "type": "string",
          "enum": ["fail-if-multiple", "newest"],
          "default": "fail-if-multiple"
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "timeoutSec": {
          "type": "integer",
          "minimum": 1,
          "default": 600
        }
      }
    },
    "deploy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "serverId",
        "remoteBaseDir",
        "failureStrategy"
      ],
      "properties": {
        "serverId": {
          "type": "string",
          "minLength": 1
        },
        "remoteBaseDir": {
          "type": "string",
          "minLength": 1,
          "description": "Remote base directory. For frontend-static: files are uploaded here (or under artifactRename subdirectory)"
        },
        "restartScript": {
          "type": "string",
          "minLength": 1,
          "description": "Path to restart script relative to project root (non-frontend projects, restart-script mode)"
        },
        "restartMode": {
          "type": "string",
          "enum": ["restart-script", "service-command"],
          "description": "Restart strategy (non-frontend projects only)"
        },
        "failureStrategy": {
          "type": "string",
          "enum": ["keep", "rollback"]
        },
        "logDir": {
          "type": "string",
          "minLength": 1,
          "description": "Remote application log directory on the target server"
        },
        "serviceMatch": {
          "type": "string",
          "minLength": 1,
          "description": "Process command line keyword used to identify the running service (service-command mode)"
        },
        "startCommand": {
          "type": "string",
          "minLength": 1
        },
        "stopCommand": {
          "type": "string",
          "minLength": 1
        },
        "restartCommand": {
          "type": "string",
          "minLength": 1
        },
        "statusCommand": {
          "type": "string",
          "minLength": 1
        },
        "targetJarPath": {
          "type": "string",
          "minLength": 1,
          "description": "Remote target JAR path (java-maven only). Defaults to remoteBaseDir/<artifact-filename>"
        },
        "backupPolicy": {
          "type": "string",
          "enum": ["backup", "replace"],
          "default": "backup",
          "description": "How to handle existing artifact on remote server (non-frontend projects only)"
        },
        "backupDir": {
          "type": "string",
          "minLength": 1,
          "description": "Subdirectory name under remoteBaseDir used to store the previous JAR (java-maven backup policy only). Always resolved relative to remoteBaseDir, e.g. 'bak' or 'archives'. Empty means 'bak'."
        }
      }
    }
  }
}
