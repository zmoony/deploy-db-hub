        * {
            font-family: "Segoe UI", "Microsoft YaHei UI", "Inter", sans-serif;
            font-size: 13px;
            letter-spacing: 0;
            outline: none;
        }
        QMainWindow {
            background-color: @C1@;
            color: @C2@;
        }
        QMainWindow > QWidget {
            background-color: @C1@;
        }
        QWidget {
            background: transparent;
            color: @C2@;
        }
        QStatusBar {
            background-color: @C25@;
            color: @C3@;
            border: none;
            border-top: 1px solid @C4@;
            padding: 4px 12px;
            selection-background-color: transparent;
            selection-color: @C3@;
            font-size: 12px;
        }
        QGroupBox, QGroupBox::title, QPushButton, QProgressBar, QToolBar {
            background: transparent;
            selection-background-color: transparent;
            selection-color: inherit;
        }
        QLabel {
            background: transparent;
            selection-background-color: @C6@;
            selection-color: @C25@;
        }
        QListWidget#sidebarNav {
            background: transparent;
            border: none;
            border-radius: 0;
            padding: 4px 0;
            outline: none;
        }
        QFrame#sidebarNavPanel {
            background-color: @C16@;
            border: 1px solid @C4@;
            border-radius: @C9@px;
        }
        QWidget#sidebarBrand {
            background-color: transparent;
            min-height: 48px;
            border-bottom: 1px solid @C4@;
        }
        QLabel#sidebarBrandMark {
            background-color: #111827; /* brand mark - stays dark */
            color: #FFFFFF;
            border-radius: 8px;
            min-width: 28px;
            max-width: 28px;
            min-height: 28px;
            max-height: 28px;
            font-size: 12px;
            font-weight: 700;
        }
        QLabel#sidebarBrandTitle {
            color: @C2@;
            font-size: 13px;
            font-weight: 600;
        }
        QFrame#sidebarDivider {
            border: none;
            background-color: @C4@;
            min-height: 1px;
            max-height: 1px;
        }
        QWidget#sidebarFooter {
            background: transparent;
        }
        QLabel#sidebarFooterText {
            color: @C3@;
            padding: 4px 8px;
            border-radius: @C5@px;
            font-weight: 400;
            font-size: 12px;
        }
        QPushButton#sidebarFooterButton {
            background-color: transparent;
            color: @C17@;
            border: none;
            padding: 0 12px;
            border-radius: 8px;
            font-weight: 400;
            text-align: left;
            font-size: 13px;
            min-height: 40px;
        }
        QPushButton#sidebarFooterButton:hover {
            background-color: @C18@;
            color: @C2@;
        }
        QPushButton#sidebarFooterButton:checked {
            background-color: @C19@;
            color: @C20@;
            font-weight: 500;
        }
        QLabel#sidebarUserText {
            color: @C3@;
            padding: 6px 8px 2px 8px;
            font-size: 11px;
        }
        QWidget#mainWorkspace {
            background-color: @C1@;
        }
        QFrame#dashboardContent {
            background: transparent;
            border: none;
        }
        QScrollArea#contentScroll {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C9@px;
        }
        QScrollArea#cardStackScroll {
            background-color: transparent;
            border: none;
            border-radius: 0;
        }
        QWidget#contentPaddingShell {
            background-color: transparent;
            border: none;
        }
        QWidget#workspacePageShell {
            background-color: @C1@;
            border: none;
        }
        QWidget#aiChatPage {
            background-color: transparent;
        }
        QListWidget#toolListNav {
            background-color: @C1@;
            border: none;
            border-radius: 0;
            padding: 4px;
            outline: none;
        }
        QListWidget#sidebarNav::item {
            background-color: transparent;
            color: @C17@;
            border-radius: @C5@px;
            padding: 0 12px;
            margin: 1px 0;
            selection-background-color: transparent;
            selection-color: @C17@;
            font-size: 14px;
            min-height: 40px;
        }
        QListWidget#sidebarNav::item:selected {
            background-color: @C19@;
            color: @C20@;
            font-weight: 500;
        }
        QListWidget#sidebarNav::item:hover {
            background-color: @C18@;
            color: @C2@;
        }
        QListWidget#toolListNav::item {
            background-color: transparent;
            color: @C3@;
            border-radius: @C5@px;
            padding: 6px 8px;
            margin: 1px 0;
            selection-background-color: transparent;
            selection-color: @C3@;
            font-size: 13px;
        }
        QListWidget#toolListNav::item:selected {
            background-color: @C7@;
            color: @C6@;
            font-weight: 500;
        }
        QListWidget#toolListNav::item:hover {
            background-color: @C8@;
        }
        QListWidget#projectListNav {
            background-color: @C1@;
            border: none;
            border-radius: 0;
            padding: 4px;
            outline: none;
        }
        QListWidget#projectListNav::item {
            background-color: transparent;
            color: @C3@;
            border: 1px solid transparent;
            border-left: 3px solid transparent;
            border-radius: @C5@px;
            padding: 7px 10px;
            margin: 2px 0;
            selection-background-color: transparent;
            selection-color: @C3@;
            font-size: 13px;
            min-height: 34px;
        }
        QListWidget#projectListNav::item:selected {
            background-color: @C7@;
            color: #1D4ED8;
            border: 1px solid #BFDBFE;
            border-left: 3px solid #2563EB;
            font-weight: 600;
        }
        QListWidget#projectListNav::item:selected:focus {
            background-color: @C8@;
            color: #1D4ED8;
            border-left: 3px solid #1D4ED8;
        }
        QListWidget#projectListNav::item:hover {
            background-color: #F1F5FF;
            color: @C2@;
        }
        QFrame#contentPanel {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C9@px;
        }
        QWidget#topBar {
            background-color: transparent;
            min-height: 48px;
            max-height: 48px;
        }
        QLabel#topBarMeta {
            color: @C3@;
            font-size: 12px;
            padding: 0 2px;
        }
        QWidget#lineTabBar,
        QWidget#moduleTabBar {
            background-color: @C25@;
            border: none;
            border-bottom: 1px solid @C4@;
            border-radius: 0;
            padding: 0 20px;
            min-height: 48px;
            max-height: 48px;
        }
        QWidget#serviceInstanceBanner {
            background-color: @C7@;
            border: 1px solid @C10@;
            border-radius: @C21@px;
        }
        QLabel#serviceInstanceTitle {
            color: @C2@;
            font-size: 14px;
            font-weight: 600;
        }
        QLabel#serviceInstanceStatusOk {
            color: #00874D;
            font-weight: 500;
            padding: 2px 8px;
            background-color: #D4F1DC;
            border-radius: @C11@px;
            font-size: 12px;
        }
        QLabel#serviceInstanceStatusBad {
            color: #CB2634;
            font-weight: 500;
            padding: 2px 8px;
            background-color: #FFECE8;
            border-radius: @C11@px;
            font-size: 12px;
        }
        QLabel#serviceInstanceNode {
            color: @C3@;
            font-size: 12px;
        }
        QLabel#serviceParentTag {
            color: @C2@;
            font-weight: 500;
            padding: 4px 8px;
            background-color: @C8@;
            border-radius: @C5@px;
            font-size: 12px;
        }
        QGroupBox#serviceHintBox {
            border: 1px solid @C4@;
        }
        QWidget#toolPlaceholderBox {
            background-color: @C1@;
            border: 1px dashed @C4@;
            border-radius: @C5@px;
            padding: 12px;
        }
        QLabel#toolMessage {
            color: @C3@;
            font-size: 12px;
        }
        QGroupBox#serviceHintBox::title {
            color: @C12@;
            font-weight: 600;
        }
        QLabel#serviceHintText {
            color: @C3@;
            font-size: 12px;
            line-height: 1.5;
        }
        QGroupBox {
            background-color: transparent;
            border: none;
            border-radius: 0;
            margin-top: 0;
            padding: 0;
            font-weight: 400;
        }
        QGroupBox::title {
            subcontrol-origin: margin;
            left: 0;
            top: 0;
            padding: 0 0 8px 0;
            color: @C2@;
            font-size: 14px;
            font-weight: 600;
        }
        QGroupBox#deployConfigBox,
        QGroupBox#dialogFormBox {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C9@px;
            margin-top: 0;
            margin-bottom: 0;
            padding: 48px 16px 16px 16px;
        }
        QFrame#deployFormCard {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C9@px;
        }
        QGroupBox#deployConfigBox::title,
        QGroupBox#dialogFormBox::title {
            subcontrol-origin: padding;
            subcontrol-position: top left;
            left: 0;
            top: 0;
            min-height: 36px;
            max-height: 36px;
            padding: 0 16px;
            background-color: @C30@;
            border-bottom: 1px solid @C4@;
            border-top-left-radius: @C9@px;
            border-top-right-radius: @C9@px;
            color: @C2@;
            font-size: 14px;
            font-weight: 600;
        }
        QGroupBox#dialogFormBox QStackedWidget,
        QGroupBox#dialogFormBox QLineEdit,
        QGroupBox#dialogFormBox QComboBox,
        QGroupBox#dialogFormBox QSpinBox,
        QWidget#pathPickerRow {
            min-width: 0;
        }
        QFrame#dialogFormPanel {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C9@px;
        }
        QWidget#dialogFormPanelHeader {
            background-color: @C1@;
            border: none;
            border-bottom: 1px solid @C4@;
            border-top-left-radius: @C9@px;
            border-top-right-radius: @C9@px;
        }
        QLabel#dialogFormPanelTitle {
            font-size: 14px;
            font-weight: 600;
            color: @C20@;
        }
        QLabel#dialogFormValueLabel {
            color: @C2@;
            font-size: 13px;
            font-weight: 500;
            background: transparent;
            border: none;
        }
        QTextEdit#dialogFormValueText {
            color: @C2@;
            font-size: 13px;
            font-weight: 400;
            background: transparent;
            border: none;
            padding: 0;
            margin: 0;
        }
        QFrame#dialogInfoTag {
            background-color: #E6F2FF;
            border: 1px solid #99CCFF;
            border-radius: @C9@px;
            min-height: 0;
            max-height: 28px;
        }
        QLabel#dialogInfoTagIcon {
            color: #0066CC;
            font-size: 14px;
            font-weight: 700;
            background: transparent;
            border: none;
            padding: 0;
            margin: 0;
        }
        QLabel#dialogInfoTagText {
            color: @C2@;
            font-size: 12px;
            background: transparent;
            border: none;
            padding: 0;
            margin: 0;
        }
        QTextEdit#dialogInfoTagText {
            color: @C2@;
            font-size: 12px;
            background: transparent;
            border: none;
            padding: 0;
            margin: 0;
            selection-background-color: #99CCFF;
            selection-color: @C2@;
        }
        QFrame#dialogHintPanel {
            background-color: @C1@;
            border: 1px solid @C4@;
            border-radius: @C9@px;
        }
        QWidget#dialogFooter {
            background-color: transparent;
            border-top: 1px solid @C4@;
            padding-top: 12px;
        }
        QScrollArea#dialogScroll {
            background-color: transparent;
            border: none;
        }
        QDialog QLabel#sectionLabel,
        QDialog QLabel#dialogHintTitle {
            margin-top: 0;
            padding: 0;
        }
        QLabel#dialogHintTitle {
            color: @C3@;
        }
        QGroupBox#deployConfigBox QLabel,
        QGroupBox#dialogFormBox QLabel {
            color: @C2@;
            font-weight: 400;
            min-width: 60px;
            font-size: 13px;
        }
        QPlainTextEdit#deployLog {
            min-height: 0;
            background-color: #141B2B;
            color: #B3C5FF;
            border: 2px solid #141B2B;
            border-radius: @C21@px;
            padding: 10px;
            font-family: "JetBrains Mono", "Consolas", "Microsoft YaHei Mono", monospace;
            font-size: 12px;
            line-height: 1.45;
            selection-background-color: @C6@;
            selection-color: @C25@;
        }
        QFrame#deploySectionCard {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C9@px;
        }
        QFrame#deploySectionHeader {
            background-color: @C30@;
            border: none;
            border-bottom: 1px solid @C4@;
            border-top-left-radius: @C9@px;
            border-top-right-radius: @C9@px;
            min-height: 36px;
            max-height: 36px;
        }
        QLabel#deploySectionTitle {
            color: @C2@;
            font-size: 14px;
            font-weight: 600;
            padding: 0;
            margin: 0;
        }
        QPushButton#deployHeaderActionButton {
            background-color: transparent;
            color: @C6@;
            border: none;
            border-radius: @C5@px;
            padding: 0 6px;
            min-height: 26px;
            max-height: 26px;
            font-size: 12px;
            font-weight: 600;
        }
        QPushButton#deployHeaderActionButton:hover {
            background-color: @C7@;
        }
        QPushButton#deployStartButton {
            background-color: @C6@;
            color: #FFFFFF;
            border: none;
            border-radius: @C5@px;
            padding: 0 12px;
            min-height: 32px;
            max-height: 32px;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.2s cubic-bezier(0.645, 0.045, 0.355, 1);
        }
        QPushButton#deployStartButton:hover {
            background-color: @C6@;
            color: #FFFFFF;
        }
        QPushButton#deployStartButton:pressed {
            background-color: #0958D9;
            color: #FFFFFF;
        }
        QPushButton#deployStartButton:disabled {
            background-color: #93C5FD;
            color: #FFFFFF;
        }
        QLabel#deployFieldLabel {
            color: @C3@;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.04em;
            padding: 0;
            margin: 0;
        }
        QLabel#logPathDisplayLabel {
            color: @C2@;
            font-size: 12px;
            padding: 0;
            margin: 0;
            min-height: 20px;
        }
        QFrame#deployStatusPanel {
            background-color: @C31@;
            border: none;
            border-radius: @C9@px;
        }
        QLabel#deployStatusDot {
            background-color: #575A5B;
            border-radius: 6px;
        }
        QLabel#deployStatusValue {
            color: @C2@;
            font-size: 14px;
            font-weight: 600;
        }
        QLabel#deployStatusHint {
            color: @C3@;
            font-size: 11px;
        }
        QLabel#deployProgressCaption,
        QLabel#deployOutputCaption {
            color: @C3@;
            font-size: 12px;
            font-weight: 600;
        }
        QLabel#deployTaskValue {
            color: @C6@;
            font-size: 12px;
            font-style: italic;
            font-weight: 600;
        }
        QLabel#deployProgressValue {
            color: @C6@;
            font-size: 13px;
            font-weight: 700;
            font-family: "JetBrains Mono", "Consolas", monospace;
        }
        QProgressBar#deployProgress {
            background-color: #E9EDFF;
            border: none;
            border-radius: 4px;
            min-height: 8px;
            max-height: 8px;
        }
        QProgressBar#deployProgress::chunk {
            background-color: @C6@;
            border-radius: 4px;
        }
        QFrame#deployOutputDivider {
            background-color: @C4@;
            border: none;
            max-height: 1px;
        }
        QFrame#deployConsoleFooter {
            background-color: @C30@;
            border: none;
            border-top: 1px solid @C4@;
            border-bottom-left-radius: @C9@px;
            border-bottom-right-radius: @C9@px;
            min-height: 28px;
            max-height: 28px;
        }
        QLabel#deployConsoleFooterText {
            color: @C3@;
            font-size: 11px;
            font-family: "JetBrains Mono", "Consolas", monospace;
        }
        QFrame#sqlWorkbenchSidebar {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C9@px;
        }
        QTreeWidget#sqlWorkbenchTree {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C5@px;
            padding: 4px;
        }
        QTreeWidget#sqlWorkbenchTree::item {
            min-height: 28px;
            padding: 2px 6px;
            border-radius: @C5@px;
            color: @C2@;
        }
        QTreeWidget#sqlWorkbenchTree::item:hover {
            background-color: @C8@;
        }
        QTreeWidget#sqlWorkbenchTree::item:selected {
            background-color: @C7@;
            color: @C6@;
        }
        QPlainTextEdit#sqlWorkbenchEditor {
            background-color: @C1@;
            border: 1px solid @C4@;
            border-radius: @C5@px;
            padding: 12px;
            min-height: 160px;
            font-family: "Cascadia Mono", "Consolas", monospace;
            font-size: 13px;
        }
        QLabel#mutedText {
            color: @C3@;
            font-size: 13px;
        }
        QLabel#pageTitle {
            font-size: 20px;
            font-weight: 700;
            color: @C2@;
            padding: 0;
            margin: 0;
        }
        QLabel#pageSubtitle {
            color: @C3@;
            font-size: 13px;
            padding: 0;
            margin: 0;
        }
        QLabel#serviceStatusBadge {
            color: @C2@;
            font-weight: 500;
            padding: 4px 10px;
            background-color: @C8@;
            border: 1px solid @C4@;
            border-radius: @C11@px;
            font-size: 12px;
        }
        QLabel#sectionLabel {
            color: @C2@;
            font-weight: 600;
            font-size: 16px;
            padding: 0;
            margin: 0;
        }
        QFrame#aiConfigSection,
        QFrame#aiQuickHelpPanel {
            background-color: @C25@;
            border: none;
            border-radius: @C9@px;
        }
        QWidget#aiConfigActions {
            min-height: 32px;
            background-color: transparent;
        }
        QPushButton#aiConfigSaveButton {
            background-color: @C6@;
            color: #FFFFFF;
            border: 1px solid @C6@;
            border-radius: @C5@px;
            font-weight: 500;
            font-size: 13px;
            min-height: 32px;
            max-height: 32px;
            padding: 0;
        }
        QPushButton#aiConfigSaveButton:hover {
            background-color: #2563EB;
            border-color: #2563EB;
        }
        QPushButton#aiConfigSaveButton:pressed {
            background-color: #1D4ED8;
            border-color: #1D4ED8;
        }
        QPushButton#aiConfigSaveButton QLabel#aiConfigActionLabel {
            color: #FFFFFF;
            background: transparent;
            border: none;
            font-weight: 500;
            font-size: 13px;
            padding: 0;
            margin: 0;
        }
        QPushButton#aiConfigTestButton {
            background-color: @C25@;
            color: @C26@;
            border: 1px solid @C4@;
            border-radius: @C5@px;
            font-weight: 500;
            font-size: 13px;
            min-height: 32px;
            max-height: 32px;
            padding: 0;
        }
        QPushButton#aiConfigTestButton:hover {
            background-color: @C8@;
            border-color: @C10@;
        }
        QPushButton#aiConfigTestButton QLabel#aiConfigActionLabel {
            color: @C26@;
            background: transparent;
            border: none;
            font-weight: 500;
            font-size: 13px;
            padding: 0;
            margin: 0;
        }
        QLabel#formFieldLabel {
            color: @C26@;
            font-size: 13px;
            font-weight: 600;
            padding: 0;
            margin: 0;
        }
        QLabel#formFieldHint,
        QLabel#quickHelpNote {
            color: @C3@;
            font-size: 12px;
            padding: 0;
            margin: 0;
        }
        QLabel#quickHelpItem {
            color: @C3@;
            font-size: 10px;
            padding: 0;
            margin: 0;
        }
        QLabel#quickHelpTitle {
            color: @C2@;
            font-size: 11px;
            font-weight: 600;
            padding: 0;
            margin: 0;
        }
        QLabel#quickHelpSectionTitle {
            font-size: 13px;
            font-weight: 600;
        }
        QLabel#quickHelpLink {
            color: #4E8EFA;
            font-size: 11px;
            font-weight: 500;
            padding: 0;
            margin: 0;
        }
        QLabel#quickHelpArrow {
            min-width: 14px;
            max-width: 14px;
        }
        QLabel#quickHelpBulb {
            min-width: 16px;
            max-width: 16px;
            min-height: 16px;
            max-height: 16px;
        }
        QWidget#quickHelpStep {
            background-color: transparent;
        }
        QLabel#quickHelpBadge {
            background-color: @C7@;
            color: @C26@;
            border-radius: 10px;
            min-width: 20px;
            max-width: 20px;
            min-height: 20px;
            max-height: 28px;
            font-size: 12px;
            font-weight: 600;
        }
        QFrame#remoteFileHeader {
            background-color: @C8@;
            border: 1px solid @C4@;
            border-radius: @C5@px;
        }
        QLabel#remoteConnectionLabel {
            color: @C2@;
            font-weight: 500;
        }
        QLabel#remoteStatusLabel {
            color: @C3@;
            font-size: 12px;
            padding: 0;
        }
        QWidget#terminalTabToolbar {
            background-color: transparent;
            min-height: 28px;
        }
        QLabel#terminalToolbarTitle {
            color: @C2@;
            font-size: 12px;
            font-weight: 600;
            padding: 0;
            margin: 0;
        }
        QPushButton#terminalToolbarButton {
            min-height: 24px;
            padding: 3px 10px;
            border-radius: @C11@px;
            background-color: @C25@;
            border: 1px solid @C4@;
            font-size: 12px;
        }
        QPushButton#terminalToolbarButton:hover {
            color: @C6@;
            background-color: @C7@;
            border-color: @C10@;
        }
        QLabel#remoteStatusDot {
            min-width: 6px;
            max-width: 6px;
            min-height: 6px;
            max-height: 6px;
            border-radius: 3px;
            margin-top: 2px;
        }
        QLabel#remoteStatusDot[level="ok"] {
            background-color: @C12@;
        }
        QLabel#remoteStatusDot[level="error"] {
            background-color: @C14@;
        }
        QLabel#remoteStatusDot[level="pending"] {
            background-color: @C13@;
        }
        QTreeWidget#remoteDirTree {
            background-color: @C25@;
            border: 1px solid @C4@;
            border-radius: @C5@px;
            padding: 4px;
        }
        QTreeWidget#remoteDirTree::item {
